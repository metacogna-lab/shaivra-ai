    "@types/node-fetch": "^2.6.11",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "jsdom": "^28.1.0",
    "msw": "^2.12.10",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "typescript": "~5.8.2",
