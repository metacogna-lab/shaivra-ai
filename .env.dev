# ==============================================
# Shaivra Intelligence Suite - Development Environment
# ==============================================
#
# Local development configuration
# Database and services use localhost defaults
# Minimal required keys for local testing
#

# --- Core Configuration ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# --- Google Gemini AI (REQUIRED) ---
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Authentication (Supabase) ---
# For local development, use Supabase Free tier or local mock
# Get from https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://localhost:54321                # Local Supabase
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9  # Mock key for local dev
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9  # Mock key for local dev

# --- JWT Secret (Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
JWT_SECRET=dev-secret-do-not-use-in-production-replace-with-256-bit-key

# --- Database (PostgreSQL via Docker) ---
# If running locally with Docker: docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:latest
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=shaivra
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shaivra

# --- Redis Cache (Local) ---
# If running locally: docker run -d -p 6379:6379 redis:latest
REDIS_URL=redis://localhost:6379

# --- Knowledge Graph (Memgraph Local) ---
# If running locally: docker run -d -p 7687:7687 memgraph/memgraph:latest
MEMGRAPH_URI=bolt://localhost:7687
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# --- Vector / Similarity Search (Qdrant Local) ---
# If running locally: docker run -d -p 6333:6333 qdrant/qdrant:latest
QDRANT_URL=http://localhost:6333

# --- Event Streaming (Redpanda Local) ---
# If running locally: docker run -d -p 9092:9092 -p 8081:8081 redpandadata/redpanda:latest
REDPANDA_BROKERS=localhost:9092

# --- File Storage (Optional - MinIO Local) ---
# If running locally: docker run -d -p 9000:9000 -p 9001:9001 minio/minio:latest server /data --console-address ":9001"
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=shaivra-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# --- OSINT Tool API Keys (Optional for local development) ---
# Get from https://account.shodan.io/ (free tier available)
SHODAN_API_KEY=

# Get from https://otx.alienvault.com/api (free tier available)
ALIENVAULT_API_KEY=

# Get from https://www.virustotal.com/gui/my-apikey (free tier available)
VIRUSTOTAL_API_KEY=

# --- Social Media APIs (Optional for local development) ---
# Get from https://developer.twitter.com/en/portal/dashboard (requires approval)
TWITTER_BEARER_TOKEN=

# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=

# --- Monitoring & Observability (Optional) ---
# For local development, tracing is disabled by default
SENTRY_DSN=

LANGSMITH_TRACING=false                 # Disable tracing in local dev (logs are verbose)
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_URL=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shaivra-intel

# --- Rate Limiting (Optional) ---
# Leave empty to use defaults. Add IPs to test rate limiting bypass
RATE_LIMIT_WHITELIST=127.0.0.1,localhost

# ==============================================
# Local Development Quick Start:
# 1. Start Docker containers (optional):
#    docker run -d -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:latest
#    docker run -d -p 6379:6379 redis:latest
# 2. Copy this file to .env: cp .env.dev .env
# 3. Fill in GEMINI_API_KEY (required)
# 4. Run: bun run dev
# ==============================================
