# ==============================================
# Shaivra Intelligence Suite - Environment Configuration
# ==============================================

# --- Core Configuration ---
NODE_ENV=development                    # development | production
PORT=3000                               # Server port
LOG_LEVEL=info                          # debug | info | warn | error

# --- Google Gemini AI (REQUIRED) ---
GEMINI_API_KEY=                         # Get from https://aistudio.google.com/app/apikey

# --- Authentication (Supabase) ---
# Get these from your Supabase project: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=                           # https://your-project.supabase.co
SUPABASE_ANON_KEY=                      # Public anon key (starts with eyJ...)
SUPABASE_SERVICE_ROLE_KEY=              # Service role key (KEEP SECRET - starts with eyJ...)

# --- JWT Secret (Generate a random 256-bit key) ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=                             # REQUIRED - Keep this secret!

# --- Database (PostgreSQL via Supabase or self-hosted) ---
POSTGRES_USER=shaivra
POSTGRES_PASSWORD=shaivra
POSTGRES_DB=shaivra
DATABASE_URL=postgresql://shaivra:shaivra@postgres:5432/shaivra

# --- Redis Cache (Optional but recommended for production) ---
REDIS_URL=redis://redis:6379

# --- Vector / Similarity Search (Qdrant) ---
QDRANT_URL=http://qdrant:6333

# --- Event Streaming (Redpanda/Kafka) ---
REDPANDA_BROKERS=redpanda:9092

# --- File Storage (S3/R2/MinIO) (Optional) ---
S3_ENDPOINT=http://minio:9000
S3_BUCKET=shaivra-uploads
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1

# --- OSINT Tool API Keys (Optional but recommended for full functionality) ---
SHODAN_API_KEY=                         # Get from https://account.shodan.io/
ALIENVAULT_API_KEY=                     # Get from https://otx.alienvault.com/api
VIRUSTOTAL_API_KEY=                     # Get from https://www.virustotal.com/gui/my-apikey

# --- Social Media APIs (Optional) ---
TWITTER_BEARER_TOKEN=                   # Twitter API v2 Bearer Token
REDDIT_CLIENT_ID=                       # Reddit OAuth Client ID
REDDIT_CLIENT_SECRET=                   # Reddit OAuth Client Secret
REDDIT_REFRESH_TOKEN=                   # Reddit OAuth Refresh Token

# --- Monitoring & Observability (Optional) ---
SENTRY_DSN=                             # Sentry error tracking DSN
LANGSMITH_API_KEY=                      # LangSmith API key for LLM tracing (Get from https://smith.langchain.com)
LANGSMITH_API_URL=https://api.smith.langchain.com  # LangSmith API endpoint
LANGSMITH_PROJECT=shaivra-intelligence  # LangSmith project name for this deployment

# --- Rate Limiting (Optional) ---
RATE_LIMIT_WHITELIST=                   # Comma-separated IPs to exempt from rate limiting

# ==============================================
# Quick Start (Local Development):
# 1. Copy this file to .env: cp .env.example .env
# 2. Fill in GEMINI_API_KEY (REQUIRED)
# 3. Fill in Supabase credentials for authentication
# 4. Generate and set JWT_SECRET
# 5. Run: bun run dev
# ==============================================

# ==============================================
# Railway Deployment:
# 1. Push to GitHub
# 2. Connect Railway to your repo
# 3. Add PostgreSQL and Redis services in Railway
# 4. Set environment variables in Railway Dashboard
# 5. Deploy: railway up
#
# Railway auto-configures:
# - DATABASE_URL (from PostgreSQL service)
# - REDIS_URL (from Redis service)
# ==============================================
