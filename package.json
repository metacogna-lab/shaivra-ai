{
  "name": "shaivra-intelligence-suite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && npx prisma generate",
    "start": "node --loader tsx server.ts",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "ROLLUP_SKIP_NODEJS_NATIVE_BUILD=1 vitest run",
    "test:watch": "ROLLUP_SKIP_NODEJS_NATIVE_BUILD=1 vitest watch",
    "test:coverage": "ROLLUP_SKIP_NODEJS_NATIVE_BUILD=1 vitest run --coverage",
    "db:migrate": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:studio": "npx prisma studio",
    "railway:deploy": "railway up",
    "railway:migrate": "railway run npx prisma migrate deploy"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1002.0",
    "@aws-sdk/s3-request-presigner": "^3.1002.0",
    "@google/genai": "^1.42.0",
    "@langchain/core": "^1.1.30",
    "@langchain/google-genai": "^2.1.24",
    "@langchain/langgraph": "^1.2.0",
    "@prisma/client": "^7.4.2",
    "@supabase/supabase-js": "^2.98.0",
    "@types/d3": "^7.4.3",
    "cookie-parser": "^1.4.7",
    "csurf": "^1.11.0",
    "d3": "^7.9.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "framer-motion": "^12.34.3",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "jsonwebtoken": "^9.0.3",
    "langsmith": "^0.5.7",
    "lucide-react": "^0.575.0",
    "multer": "^2.1.1",
    "neo4j-driver": "^6.0.1",
    "node-fetch": "^3.3.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.1",
    "snoowrap": "^1.23.0",
    "tsx": "^4.21.0",
    "twitter-api-v2": "^1.29.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
