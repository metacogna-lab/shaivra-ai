# ==============================================
# Shaivra Intelligence Suite - Production Environment
# ==============================================
#
# Railway production deployment configuration
# Uses environment variables from Railway services
# NEVER commit secrets - set these in Railway dashboard
#

# --- Core Configuration ---
NODE_ENV=production
PORT=8080                               # Railway default port (override if needed)
LOG_LEVEL=info                          # Production: use info level

# --- Google Gemini AI (REQUIRED) ---
# Set in Railway Dashboard Variables
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Authentication (Supabase Production) ---
# Set in Railway Dashboard Variables
# Get from your production Supabase project: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- JWT Secret (Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))") ---
# CRITICAL: Generate a new strong secret for production
# Set in Railway Dashboard Variables (NOT in this file)
JWT_SECRET=

# --- Database (PostgreSQL via Railway) ---
# Railway auto-configures DATABASE_URL when you attach PostgreSQL service
# If manually configuring: ensure you use production credentials
# DO NOT set POSTGRES_USER/PASSWORD directly - use DATABASE_URL only
DATABASE_URL=

# --- Redis Cache (via Railway or external) ---
# Railway auto-configures REDIS_URL when you attach Redis service
# If using external: set production URL with strong authentication
REDIS_URL=

# --- Knowledge Graph (Memgraph or Neo4j) ---
# Production: use managed service (Memgraph Cloud or Neo4j Aura)
# Example Memgraph Cloud: bolt+s://hostname:7687
MEMGRAPH_URI=
MEMGRAPH_USER=
MEMGRAPH_PASSWORD=

# --- Vector / Similarity Search (Qdrant) ---
# Production: use managed Qdrant Cloud service
# Example: https://project-id.qdrant.io
QDRANT_URL=

# --- Event Streaming (Redpanda or Kafka) ---
# Production: use Upstash Kafka or self-hosted cluster
REDPANDA_BROKERS=

# --- File Storage (S3/R2) ---
# Recommended: Cloudflare R2 (S3-compatible, lower cost)
# Get from https://dash.cloudflare.com/
S3_ENDPOINT=
S3_BUCKET=shaivra-uploads-prod
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=auto

# --- OSINT Tool API Keys (Production) ---
# Shodan: $49/month Essential plan
# Get from https://account.shodan.io/
SHODAN_API_KEY=

# AlienVault OTX: Free tier
# Get from https://otx.alienvault.com/api
ALIENVAULT_API_KEY=

# VirusTotal: Free tier (4 requests/min)
# Get from https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# --- Social Media APIs (Production) ---
# Twitter API v2: $100/month Basic plan
# Get from https://developer.twitter.com/en/portal/dashboard
TWITTER_BEARER_TOKEN=

# Reddit API: Free (rate limited: 60 requests/min)
# Get from https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=

# --- Monitoring & Observability (Recommended for Production) ---
# Error tracking with Sentry
# Get from https://sentry.io/
SENTRY_DSN=

# LLM monitoring with LangSmith
# Enable tracing for production visibility
LANGSMITH_TRACING=true
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_URL=https://api.smith.langchain.com
# Get from https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=shaivra-intel-prod

# --- Rate Limiting (Production) ---
# Whitelist internal IPs only (load balancers, monitoring)
# Leave empty for defaults
RATE_LIMIT_WHITELIST=

# ==============================================
# Railway Deployment Setup:
# ==============================================
#
# 1. Create Railway project:
#    - Go to https://railway.app/dashboard
#    - Click "New Project" → "Deploy from GitHub"
#    - Select your shaivra-intelligence-suite repo
#
# 2. Add services in Railway:
#    a. PostgreSQL: Click "Add" → "PostgreSQL"
#       - Railway auto-generates DATABASE_URL ✓
#    b. Redis: Click "Add" → "Redis"
#       - Railway auto-generates REDIS_URL ✓
#    c. Node.js App: Should auto-detect from package.json
#
# 3. Set environment variables in Railway Dashboard:
#    - Go to Variables tab in your Railway project
#    - Add all variables marked "Set in Railway Dashboard Variables" above
#    - IMPORTANT: Keep secrets out of git, use Railway's secret system
#
# 4. Configure deployment settings:
#    - Build Command: `bun run build`
#    - Start Command: `bun run start`
#    - Root Directory: `/` (default)
#
# 5. Deploy:
#    - Push to main branch, Railway auto-deploys
#    - Monitor at https://railway.app/dashboard
#
# ==============================================
# Environment Variable Priority:
# ==============================================
#
# Variables AUTO-SET by Railway:
# - DATABASE_URL (from PostgreSQL service)
# - REDIS_URL (from Redis service)
# - PORT (Railway manages this)
#
# Variables YOU MUST SET in Railway Dashboard:
# - GEMINI_API_KEY
# - SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY
# - JWT_SECRET (generate new for production)
# - S3_ENDPOINT, S3_ACCESS_KEY_ID, S3_SECRET_ACCESS_KEY, S3_BUCKET
# - All OSINT API keys (Shodan, AlienVault, VirusTotal)
# - All social media tokens (Twitter, Reddit)
# - LANGSMITH_API_KEY (optional but recommended)
# - SENTRY_DSN (optional but recommended)
#
# ==============================================
# Security Checklist:
# ==============================================
#
# Before deploying to production:
# - [ ] No hardcoded secrets in .env.prod file in git
# - [ ] All secrets set in Railway Dashboard (NOT in code)
# - [ ] JWT_SECRET is a fresh 256-bit random value
# - [ ] DATABASE_URL uses strong password (auto-set by Railway)
# - [ ] REDIS_URL uses authentication (auto-set by Railway)
# - [ ] S3 credentials limited to specific bucket (R2 recommended)
# - [ ] API keys have appropriate rate limits and IP restrictions
# - [ ] HTTPS enforced (Railway provides SSL by default)
# - [ ] Monitoring active (Sentry DSN configured)
# - [ ] Logs stored securely (Railway manages this)
#
# ==============================================
# Cost Estimation (Monthly):
# ==============================================
#
# Railway Pricing:
# - Free tier: $5 credit/month
# - Usage after free tier: ~$0.00001667/CPU-hour, ~$0.00003333/GB-hour
# - Typical small app: $10-30/month
#
# External Services (Optional):
# - Shodan: $49/month (Essential plan)
# - Twitter API: $100/month (Basic plan)
# - Cloudflare R2: $0.015/GB stored + $0.015/GB download
# - Sentry: Free tier (5K events/month) or Pro ($29/month)
# - LangSmith: Free tier or Pro
#
# Total estimated: $150-250/month with all services
#
# ==============================================
